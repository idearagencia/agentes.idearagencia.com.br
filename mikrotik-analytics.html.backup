<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>MICROTIK ANALYTICS — InfraHacks</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root {
 --bg: #141414;
 --card-bg: #1a1a1a;
 --card-border: #333;
 --text-main: #ffffff;
 --text-sec: #A5A5A5;
 --primary: #EC1D3A;
 --accent: #00d4ff;
 --success: #00ff88;
 --warning: #ffaa00;
 --danger: #ff4444;
 --info: #00bcd4;
}
* { margin:0; padding:0; box-sizing:border-box; }
body {
 font-family: Inter, -apple-system, sans-serif;
 background: var(--bg);
 color: var(--text-main);
 min-height: 100vh;
 margin: 0;
 padding: 0;
}
.header {
 background: linear-gradient(180deg, #1a1a1a 0%, #141414 100%);
 border-bottom: 1px solid var(--card-border);
 padding: 20px 24px;
 display: flex;
 align-items: center;
 gap: 16px;
}
.logo {
 width: 48px; height: 48px;
 background: var(--accent);
 border-radius: 12px;
 display:flex; align-items:center; justify-content:center;
 font-size: 24px;
 box-shadow: 0 4px 12px rgba(0,212,255,0.3);
}
.title h1 {
 font-size: 20px;
 font-weight: 800;
 letter-spacing: 1px;
 color: var(--text-main);
}
.title p {
 font-size: 12px;
 color: var(--text-sec);
 margin-top: 4px;
}
.back-link {
 margin-left: auto;
 color: var(--text-sec);
 text-decoration: none;
 font-size: 13px;
 display: flex;
 align-items: center;
 gap: 6px;
 padding: 8px 16px;
 border: 1px solid var(--card-border);
 border-radius: 8px;
 transition: all 0.2s ease;
}
.back-link:hover {
 color: var(--text-main);
 border-color: var(--accent);
 background: rgba(0,212,255,0.1);
}
.container {
 max-width: 1800px;
 margin: 0 auto;
 padding: 24px;
}
.update-time {
 text-align: right;
 font-size: 11px;
 color: var(--text-sec);
 margin-bottom: 8px;
}
.stats-grid {
 display: grid;
 grid-template-columns: repeat(4, 1fr);
 gap: 20px;
 margin-bottom: 32px;
}
.stat-card {
 background: var(--card-bg);
 border: 1px solid var(--card-border);
 border-radius: 16px;
 padding: 20px;
 position: relative;
 transition: all 0.3s ease;
}
.stat-card:hover {
 transform: translateY(-4px);
 border-color: var(--accent);
 box-shadow: 0 16px 32px rgba(0,0,0,0.4);
}
.stat-card::before {
 content: '';
 position: absolute;
 top: 0; left: 0; right: 0; height: 3px;
 background: var(--accent);
}
.stat-icon {
 font-size: 24px;
 margin-bottom: 12px;
}
.stat-value {
 font-family: "JetBrains Mono", monospace;
 font-size: 32px;
 font-weight: 800;
 color: var(--text-main);
 margin-bottom: 4px;
}
.stat-label {
 font-size: 12px;
 color: var(--text-sec);
 font-weight: 600;
 text-transform: uppercase;
 letter-spacing: 0.5px;
}
.stat-delta {
 font-size: 11px;
 margin-top: 8px;
 display: flex;
 align-items: center;
 gap: 4px;
}
.stat-delta.up { color: var(--danger); }
.stat-delta.down { color: var(--success); }
.log-level-indicator {
 display: flex;
 gap: 8px;
 margin-top: 12px;
}
.level-dot {
 width: 12px; height: 12px;
 border-radius: 50%;
 flex-shrink: 0;
}
.level-dot.error { background: var(--danger); }
.level-dot.warning { background: var(--warning); }
.level-dot.info { background: var(--info); }
.level-dot.debug { background: var(--text-sec); }
.dashboard-grid {
 display: grid;
 grid-template-columns: 2fr 1fr;
 gap: 24px;
 margin-bottom: 32px;
}
.chart-card {
 background: var(--card-bg);
 border: 1px solid var(--card-border);
 border-radius: 16px;
 padding: 24px;
}
.chart-header {
 display: flex;
 justify-content: space-between;
 align-items: center;
 margin-bottom: 24px;
}
.chart-title {
 font-size: 16px;
 font-weight: 700;
 color: var(--text-main);
}
.chart-subtitle {
 font-size: 11px;
 color: var(--text-sec);
 margin-top: 4px;
}
.chart-legend {
 display: flex;
 gap: 16px;
 font-size: 11px;
}
.legend-item {
 display: flex;
 align-items: center;
 gap: 6px;
}
.legend-dot {
 width: 8px; height: 8px;
 border-radius: 50%;
}
.timeline-chart {
 height: 200px;
 background: rgba(255,255,255,0.03);
 border-radius: 12px;
 position: relative;
 overflow: hidden;
 display: flex;
 align-items: flex-end;
 padding: 12px;
 gap: 4px;
}
.timeline-bar {
 flex: 1;
 background: linear-gradient(180deg, var(--accent) 0%, rgba(0,212,255,0.3) 100%);
 border-radius: 4px 4px 0 0;
 min-height: 4px;
 transition: height 0.5s ease;
 position: relative;
}
.timeline-bar:hover::after {
 content: attr(data-value);
 position: absolute;
 bottom: 100%;
 left: 50%;
 transform: translateX(-50%);
 background: var(--text-main);
 color: var(--bg);
 padding: 4px 8px;
 border-radius: 4px;
 font-size: 10px;
 font-weight: 600;
 white-space: nowrap;
 margin-bottom: 4px;
 z-index: 10;
}
.recent-logs {
 background: var(--card-bg);
 border: 1px solid var(--card-border);
 border-radius: 16px;
 padding: 24px;
}
.logs-header {
 display: flex;
 justify-content: space-between;
 align-items: center;
 margin-bottom: 20px;
}
.logs-list {
 max-height: 400px;
 overflow-y: auto;
}
.log-entry {
 display: grid;
 grid-template-columns: 80px 100px 1fr;
 gap: 12px;
 padding: 12px;
 border-radius: 8px;
 margin-bottom: 8px;
 background: rgba(255,255,255,0.03);
 font-size: 12px;
 font-family: "JetBrains Mono", monospace;
 transition: all 0.2s ease;
 border-left: 3px solid transparent;
}
.log-entry:hover {
 background: rgba(255,255,255,0.06);
}
.log-entry.error { border-left-color: var(--danger); }
.log-entry.warning { border-left-color: var(--warning); }
.log-entry.info { border-left-color: var(--info); }
.log-entry.debug { border-left-color: var(--text-sec); }
.log-time { color: var(--text-sec); }
.log-level {
 font-weight: 700;
 text-transform: uppercase;
 padding: 2px 8px;
 border-radius: 4px;
 font-size: 10px;
}
.log-level.error { color: var(--danger); background: rgba(255,68,68,0.15); }
.log-level.warning { color: var(--warning); background: rgba(255,170,0,0.15); }
.log-level.info { color: var(--info); background: rgba(0,188,212,0.15); }
.log-level.debug { color: var(--text-sec); background: rgba(165,165,165,0.15); }
.log-source { color: var(--text-sec); }
.log-message { color: var(--text-main); line-height: 1.4; word-break: break-word; }
.top-sources {
 background: var(--card-bg);
 border: 1px solid var(--card-border);
 border-radius: 16px;
 padding: 24px;
}
.source-item {
 display: flex;
 align-items: center;
 justify-content: space-between;
 padding: 12px;
 margin-bottom: 8px;
 background: rgba(255,255,255,0.03);
 border-radius: 8px;
 transition: all 0.2s ease;
}
.source-item:hover {
 background: rgba(255,255,255,0.06);
 transform: translateX(4px);
}
.source-name {
 font-weight: 600;
 color: var(--text-main);
}
.source-count {
 font-family: "JetBrains Mono", monospace;
 color: var(--accent);
 font-weight: 700;
}
.source-bar {
 height: 4px;
 background: rgba(255,255,255,0.1);
 border-radius: 2px;
 margin-top: 8px;
 overflow: hidden;
}
.source-bar-fill {
 height: 100%;
 background: var(--accent);
 border-radius: 2px;
 transition: width 0.5s ease;
}
.filter-bar {
 display: flex;
 gap: 12px;
 margin-bottom: 20px;
 flex-wrap: wrap;
}
.filter-btn {
 padding: 8px 16px;
 border: 1px solid var(--card-border);
 background: transparent;
 color: var(--text-sec);
 border-radius: 8px;
 font-size: 12px;
 font-weight: 600;
 cursor: pointer;
 transition: all 0.2s ease;
}
.filter-btn:hover {
 border-color: var(--accent);
 color: var(--text-main);
}
.filter-btn.active {
 background: var(--accent);
 color: var(--bg);
 border-color: var(--accent);
}
.search-box {
 flex: 1;
 min-width: 200px;
 padding: 8px 16px;
 border: 1px solid var(--card-border);
 background: transparent;
 color: var(--text-main);
 border-radius: 8px;
 font-size: 12px;
}
.search-box:focus {
 outline: none;
 border-color: var(--accent);
 box-shadow: 0 0 0 3px rgba(0,212,255,0.1);
}
.search-box::placeholder {
 color: var(--text-sec);
}
.footer {
 text-align: center;
 padding: 40px 20px;
 border-top: 1px solid var(--card-border);
 margin-top: 40px;
 color: var(--text-sec);
 font-size: 12px;
}
.footer a { color: var(--accent); text-decoration: none; }
@keyframes fadeIn {
 from { opacity: 0; transform: translateY(20px); }
 to { opacity: 1; transform: translateY(0); }
}
.stat-card { animation: fadeIn 0.5s ease backwards; }
.stat-card:nth-child(1) { animation-delay: 0.1s; }
.stat-card:nth-child(2) { animation-delay: 0.2s; }
.stat-card:nth-child(3) { animation-delay: 0.3s; }
.stat-card:nth-child(4) { animation-delay: 0.4s; }
@media (max-width: 1200px) {
 .dashboard-grid { grid-template-columns: 1fr; }
 .stats-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 768px) {
 .stats-grid { grid-template-columns: 1fr; }
 .log-entry { grid-template-columns: 1fr; gap: 6px; }
 .filter-bar { flex-direction: column; }
 .search-box { width: 100%; }
}
::-webkit-scrollbar {
 width: 8px;
 height: 8px;
}
::-webkit-scrollbar-track {
 background: rgba(255,255,255,0.03);
 border-radius: 4px;
}
::-webkit-scrollbar-thumb {
 background: rgba(255,255,255,0.2);
 border-radius: 4px;
}
::-webkit-scrollbar-thumb:hover {
 background: rgba(255,255,255,0.3);
}
</style>
</head>
<body>
  <header class="header">
    <div class="logo">📊</div>
    <div class="title">
      <h1>MICROTIK ANALYTICS</h1>
      <p>Análise de Logs em Tempo Real — Powered by InfraHacks</p>
    </div>
    <a href="/index.html" class="back-link">← Voltar ao Dashboard</a>
  </header>
  <main class="container">
    <div class="update-time" id="update-time">Atualizado: --</div>
    
    <div class="stats-grid" id="stats-grid">
      <div class="stat-card">
        <div class="stat-icon">📝</div>
        <div class="stat-value" id="total-logs">0</div>
        <div class="stat-label">Total de Logs</div>
        <div class="log-level-indicator">
          <div class="level-dot error"></div>
          <div class="level-dot warning"></div>
          <div class="level-dot info"></div>
          <div class="level-dot debug"></div>
        </div>
      </div>
      <div class="stat-card" style="--accent: var(--danger)">
        <div class="stat-icon">⚠️</div>
        <div class="stat-value" id="error-count">0</div>
        <div class="stat-label">Erros Críticos</div>
        <div class="stat-delta" id="error-delta">
          <span>↑</span> <span>+0</span>
        </div>
      </div>
      <div class="stat-card" style="--accent: var(--warning)">
        <div class="stat-icon">🔶</div>
        <div class="stat-value" id="warning-count">0</div>
        <div class="stat-label">Warnings</div>
        <div class="stat-delta" id="warning-delta">
          <span>↓</span> <span>-0</span>
        </div>
      </div>
      <div class="stat-card" style="--accent: var(--success)">
        <div class="stat-icon">🔍</div>
        <div class="stat-value" id="uptime">99.9%</div>
        <div class="stat-label">Uptime Router</div>
        <div class="stat-delta" id="uptime-delta">
          <span>→</span> <span>Estável</span>
        </div>
      </div>
    </div>

    <div class="dashboard-grid">
      <div class="chart-card">
        <div class="chart-header">
          <div>
            <div class="chart-title">Tráfego de Logs por Nível</div>
            <div class="chart-subtitle">Última hora • Atualizado em tempo real</div>
          </div>
          <div class="chart-legend">
            <div class="legend-item"><div class="legend-dot" style="background:var(--danger)"></div>Error</div>
            <div class="legend-item"><div class="legend-dot" style="background:var(--warning)"></div>Warning</div>
            <div class="legend-item"><div class="legend-dot" style="background:var(--info)"></div>Info</div>
          </div>
        </div>
        <div class="timeline-chart" id="timeline-chart"></div>
      </div>

      <div class="top-sources">
        <div class="chart-header">
          <div>
            <div class="chart-title">Top Fontes</div>
            <div class="chart-subtitle">Origem dos logs</div>
          </div>
        </div>
        <div id="sources-list"></div>
      </div>
    </div>

    <div class="recent-logs">
      <div class="logs-header">
        <div class="chart-title">Logs Recentes</div>
        <div class="filter-bar">
          <button class="filter-btn active" data-filter="all">Todos</button>
          <button class="filter-btn" data-filter="error">Erros</button>
          <button class="filter-btn" data-filter="warning">Warnings</button>
          <button class="filter-btn" data-filter="info">Info</button>
          <input type="text" class="search-box" id="log-search" placeholder="🔍 Buscar logs...">
        </div>
      </div>
      <div class="logs-list" id="logs-list"></div>
    </div>
  </main>
  <footer class="footer">
    <p>© 2025 InfraHacks — MikroTik Analytics v1.0 — Powered by OpenClaw</p>
    <p style="margin-top: 8px; font-size: 11px;">
      <a href="https://mikrotik.com" target="_blank">MikroTik®</a> é uma marca registrada da MikroTik<br>
      Dados processados localmente • Nenhum log é enviado para a nuvem
    </p>
  </footer>
<script>
// Estado da aplicação
let allLogs = [];
let filteredLogs = [];
let currentFilter = 'all';
let searchQuery = '';

// Gera dados simulados de logs do MikroTik
function generateMockLogs(count = 100) {
  const levels = ['error', 'warning', 'info', 'debug'];
  const sources = [
    'firewall', 'dhcp', 'routeros', 'system', 'winbox', 'ns',
    'ntp', 'dns', 'queue', 'hotspot', 'ppp', 'ipsec'
  ];
  const messages = {
    error: [
      'Connection failed: timeout',
      'Interface down: ether1',
      'Login attempt blocked',
      'Firewall rule mismatch',
      'DNS resolution failed',
      'BGP session reset',
      'IPsec tunnel disconnected',
      'Memory usage critical: 95%',
      'CPU overload detected',
      'Bridge loop detected'
    ],
    warning: [
      'High CPU usage detected',
      'Interface flapping detected',
      'Multiple auth failures',
      'Config backup failed',
      'License expires in 7 days',
      'Queue tree overflow',
      'Hotspot user limit reached',
      'Static route unreachable',
      'BGP keepalive timeout',
      'Low disk space warning'
    ],
    info: [
      'System boot completed',
      'User admin logged in',
      'Configuration change saved',
      'Backup created successfully',
      'Scheduler job executed',
      'Interface ether1 up',
      'DHCP lease granted',
      'Firewall connection tracked',
      'NTP synchronized',
      'VPN tunnel established'
    ],
    debug: [
      'Processing packet from 192.168.1.100',
      'Route lookup: 0.0.0.0/0 via 10.0.0.1',
      'ARP cache updated',
      'Queue tree stats collected',
      'Hotspot session validated',
      'DHCP discover received',
      'DNS query processed',
      'Log rotation completed',
      'Cleanup old connections',
      'Gateway check passed'
    ]
  };
  
  const logs = [];
  const now = Date.now();
  
  for (let i = 0; i < count; i++) {
    const level = levels[Math.floor(Math.random() * levels.length)];
    const source = sources[Math.floor(Math.random() * sources.length)];
    const levelMessages = messages[level];
    const message = levelMessages[Math.floor(Math.random() * levelMessages.length)];
    const timestamp = new Date(now - Math.floor(Math.random() * 3600000)).toISOString();
    
    logs.push({
      id: i,
      timestamp,
      level,
      source,
      message,
      ip: `${Math.floor(Math.random()*255)}.${Math.floor(Math.random()*255)}.${Math.floor(Math.random()*255)}.${Math.floor(Math.random()*255)}`
    });
  }
  
  return logs.sort((a, b) => new Date(b.timestamp) - new Date(a.timestamp));
}

// Formata data/hora
function formatTime(isoString) {
  const date = new Date(isoString);
  return date.toLocaleString('pt-BR', { 
    day: '2-digit', month: '2-digit', year: 'numeric',
    hour: '2-digit', minute: '2-digit', second: '2-digit'
  });
}

// Filtra logs
function filterLogs() {
  filteredLogs = allLogs.filter(log => {
    const matchesFilter = currentFilter === 'all' || log.level === currentFilter;
    const matchesSearch = !searchQuery || 
      log.message.toLowerCase().includes(searchQuery.toLowerCase()) ||
      log.source.toLowerCase().includes(searchQuery.toLowerCase()) ||
      log.ip.includes(searchQuery);
    return matchesFilter && matchesSearch;
  });
  renderLogs();
}

// Renderiza lista de logs
function renderLogs() {
  const logsList = document.getElementById('logs-list');
  const logsToShow = filteredLogs.slice(0, 50);
  
  if (logsToShow.length === 0) {
    logsList.innerHTML = `
      <div style="text-align:center;padding:40px;color:var(--text-sec)">
        <div style="font-size:40px;margin-bottom:12px">📭</div>
        <div>Nenhum log encontrado</div>
      </div>
    `;
    return;
  }
  
  logsList.innerHTML = logsToShow.map(log => `
    <div class="log-entry ${log.level}" data-id="${log.id}">
      <div class="log-time">${formatTime(log.timestamp)}</div>
      <div class="log-level ${log.level}">${log.level}</div>
      <div class="log-source">${log.source}</div>
      <div class="log-message">${log.message}</div>
    </div>
  `).join('');
}

// Renderiza estatísticas
function renderStats(stats) {
  document.getElementById('total-logs').textContent = stats.total.toLocaleString();
  document.getElementById('error-count').textContent = stats.errors.toLocaleString();
  document.getElementById('warning-count').textContent = stats.warnings.toLocaleString();
  
  // Uptime simulado
  const uptime = 99.9 + Math.random() * 0.099;
  document.getElementById('uptime').textContent = uptime.toFixed(3) + '%';
  
  // Deltas
  const errorDelta = document.getElementById('error-delta');
  errorDelta.innerHTML = `<span>${Math.random() > 0.5 ? '↑' : '↓'}</span> <span>${Math.random() > 0.5 ? '+' : '-'}${Math.floor(Math.random() * 10)}</span>`;
  errorDelta.className = 'stat-delta ' + (Math.random() > 0.3 ? 'up' : 'down');
  
  const warningDelta = document.getElementById('warning-delta');
  warningDelta.innerHTML = `<span>${Math.random() > 0.5 ? '↑' : '↓'}</span> <span>${Math.random() > 0.5 ? '+' : '-'}${Math.floor(Math.random() * 20)}</span>`;
  warningDelta.className = 'stat-delta ' + (Math.random() > 0.5 ? 'up' : 'down');
  
  // Timeline chart
  renderTimeline(stats.timeline);
  
  // Top sources
  renderTopSources(stats.sources);
}

// Renderiza gráfico de timeline
function renderTimeline(data) {
  const chart = document.getElementById('timeline-chart');
  const max = Math.max(...data);
  
  chart.innerHTML = data.map((value, idx) => {
    const hour = new Date().getHours() - (12 - idx);
    const displayHour = hour < 0 ? hour + 24 : hour;
    const height = (value / max) * 100;
    
    return `
      <div class="timeline-bar" 
           style="height:${height}%; opacity:${0.4 + (value/max)*0.6}"
           data-value="${value} logs"
           title="${displayHour}h: ${value} logs">
      </div>
    `;
  }).join('');
}

// Renderiza top fontes
function renderTopSources(sources) {
  const list = document.getElementById('sources-list');
  const max = sources[0]?.count || 1;
  
  list.innerHTML = sources.map(src => `
    <div class="source-item">
      <div>
        <div class="source-name">${src.name}</div>
        <div class="source-bar">
          <div class="source-bar-fill" style="width:${(src.count/max)*100}%"></div>
        </div>
      </div>
      <div class="source-count">${src.count}</div>
    </div>
  `).join('');
}

// Calcula estatísticas a partir dos logs
function calculateStats() {
  const stats = {
    total: allLogs.length,
    errors: allLogs.filter(l => l.level === 'error').length,
    warnings: allLogs.filter(l => l.level === 'warning').length,
    info: allLogs.filter(l => l.level === 'info').length,
    debug: allLogs.filter(l => l.level === 'debug').length
  };
  
  // Timeline por hora (últimas 12 horas)
  const hours = [];
  const now = Date.now();
  for (let i = 11; i >= 0; i--) {
    const hourStart = new Date(now - i * 3600000);
    const hourEnd = new Date(hourStart.getTime() + 3600000);
    const count = allLogs.filter(log => {
      const logTime = new Date(log.timestamp);
      return logTime >= hourStart && logTime < hourEnd;
    }).length;
    hours.push(count);
  }
  stats.timeline = hours;
  
  // Top fontes
  const sourceCounts = {};
  allLogs.forEach(log => {
    sourceCounts[log.source] = (sourceCounts[log.source] || 0) + 1;
  });
  stats.sources = Object.entries(sourceCounts)
    .map(([name, count]) => ({ name, count }))
    .sort((a, b) => b.count - a.count)
    .slice(0, 5);
  
  return stats;
}

// Atualiza tempo
function updateTime() {
  const now = new Date();
  document.getElementById('update-time').textContent = 
    'Atualizado: ' + now.toLocaleString('pt-BR', { 
      day: '2-digit', month: '2-digit', year: 'numeric',
      hour: '2-digit', minute: '2-digit', second: '2-digit'
    });
}

// Inicialização
function init() {
  // Gera logs mock
  allLogs = generateMockLogs(200);
  filteredLogs = [...allLogs];
  
  // Renderiza inicial
  const stats = calculateStats();
  renderStats(stats);
  renderLogs();
  updateTime();
  
  // Simula atualização em tempo real
  setInterval(() => {
    // Adiciona novos logs aleatórios
    const newLogs = generateMockLogs(5);
    allLogs = [...newLogs, ...allLogs].slice(0, 500); // mantém últimos 500
    filterLogs();
    const newStats = calculateStats();
    renderStats(newStats);
    updateTime();
  }, 10000);
  
  // Event listeners
  document.querySelectorAll('.filter-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      currentFilter = btn.getAttribute('data-filter');
      filterLogs();
    });
  });
  
  document.getElementById('log-search').addEventListener('input', (e) => {
    searchQuery = e.target.value;
    filterLogs();
  });
}

document.addEventListener('DOMContentLoaded', init);
</script>
</body>
</html>
